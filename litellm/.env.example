# LiteLLM Master Key — used to authenticate requests to the proxy
# Generate one with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-changeme

# Optional: add provider API keys if needed directly in env
# (alternatively, set them in litellm_config.yaml via litellm_params)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=
